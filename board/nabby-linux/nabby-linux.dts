/dts-v1/;
#include "nabby-linux.dtsi"
#include <dt-bindings/gpio/gpio.h>

/ {
	model = "Nabby Linux Board"; 
	compatible = "allwinner,suniv-f1c100s";

	aliases {
		serial0 = &uart0;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	reg_vcc3v3: vcc3v3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;
	};
};

/*
 * Pin Definitions
 */



/* Define pinctrl groups added by Raj* /
&pinctrl {
            my_input_pin_pe3: my-input-right {                 / *pio pin added Raj * /
                pins = "PE3"; / * RIGHT button * /
                function = "gpio";
                bias-pull-up;        / * optional * /
                input-enable;
            };

           my_input_pin_pe6: my-input-left {                 / *pio pin added Raj * /
                pins = "PE6"; / * LEFT button * /
                function = "gpio";
                bias-pull-up;        / * optional * /
                input-enable;
            };
}; */

/* Exposing the gpio-keys. added by Raj * /
gpio_keys: gpio-keys {
    compatible = "gpio-keys";

    di_right: di-right {
        label = "DI_RIGHT";
        linux,code = <1>;
        gpios = <&pio 4 3 GPIO_ACTIVE_LOW>; / * PE3 = bank 4, pin 3 * /
        pinctrl-names = "default";
        pinctrl-0 = <&my_input_pin_pe3>;
        debounce-interval = <10>;
    };

    di_left: di-left {
        label = "DI_LEFT";
        linux,code = <2>;
        gpios = <&pio 4 6 GPIO_ACTIVE_LOW>; / * PE6 = bank 4, pin 6 * /
        pinctrl-names = "default";
        pinctrl-0 = <&my_input_pin_pe6>;
        debounce-interval = <10>;
    };
}; */




/*
&be0 {
	status = "okay";
};

&de {
	status = "okay";
};
*/

&spi0 {
	pinctrl-names = "default";
	pinctrl-0 = <&spi0_pins_a>;
	status = "okay";

	flash@0 {
		#address-cells = <1>;
		#size-cells = <1>;
		compatible = "xtx,xt25f256", "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <40000000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "u-boot";
				reg = <0x000000 0x100000>;
				read-only;
			};

			partition@1 {
				label = "dtb";
				reg = <0x100000 0x10000>;
				read-only;
			};

			partition@2 {
				label = "kernel";
				reg = <0x110000 0x4F0000>;
				read-only;
			};

			partition@3 {
				label = "rootfs";
				reg = <0x600000 0x1A00000>;
			};
		};
	};
};

&spi1 {
    status = "okay";
    pinctrl-names = "default";
    pinctrl-0 = <&spi1_pins>;

    display@0 {
        compatible = "ilitek,ili9341";
        reg = <0>;                       // CS0
        spi-max-frequency = <8000000>;
        spi-cpol;                           /* SPI mode 3 */ //added 9/4
        spi-cpha;                              //added 9/4
        dc-gpios = <&pio 3 16 GPIO_ACTIVE_HIGH>; // PD = 3
        reset-gpios = <&pio 3 17 GPIO_ACTIVE_LOW>;
      /*  backlight = <&backlight_pin>; */

        rotation = <270>;                // Optional
        buswidth = <8>;                  /* ADD THIS */
        rgb;                              // Use RGB pixel order if needed

        status = "okay";
        /* force full reinit on every use */
        always-update;
    };
};

&uart0 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart0_pe_pins>;
	status = "okay";
};

&otg_sram {
	status = "okay";
};

&usb_otg {
	dr_mode = "host";
	status = "okay";
};

&usbphy {
	usb0_id_det = <&pio 4 2 GPIO_ACTIVE_HIGH>; /* PE3 */
	status = "okay";
};
